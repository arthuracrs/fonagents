{
  "name": "fonagents",
  "version": "0.0.0",
  "description": "Manager agent + swarm orchestration on top of the Beads issue tracker.",
  "workspaces": [
    "core",
    "adapters/*",
    "daemon",
    "anagent",
    "beads-ui",
    "prompts"
  ],
  "bin": {
    "fonagents": "daemon/dist/cli.js",
    "beads-ui": "beads-ui/bin/beads-ui.js"
  },
  "files": [
    "daemon/dist/cli.js",
    "adapters/http-sse/dist/mcp-server.js",
    "anagent/dist",
    "beads-ui/bin",
    "beads-ui/dist"
  ],
  "scripts": {
    "build": "npm run build -w @fonagents/prompts && npm run build --workspaces",
    "dev": "npm run build && node daemon/dist/cli.js",
    "typecheck": "npm run typecheck --workspaces -if-present",
    "test": "npm run test --workspaces -if-present",
    "prepare": ""
  },
  "license": "ISC"
}
