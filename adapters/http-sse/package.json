{
  "name": "@fonagents/http-sse-adapter",
  "version": "0.0.0",
  "description": "HTTP + SSE adapter implementing UiCommandPort, UiEventPort, and MCP tool server for @fonagents/core.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && esbuild src/mcp-server.ts --bundle --platform=node --outfile=dist/mcp-server.js --format=cjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@fonagents/core": "^0.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
